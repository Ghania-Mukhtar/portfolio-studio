# Copy this file to ".env.local" and fill in your key, then restart `npm run dev`.
# Get a key at https://console.anthropic.com/  ->  Settings -> API Keys.
# This key stays on the server (it is read only by the /api routes); it is
# never sent to the browser and never committed to the repo.

ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional. Defaults to claude-sonnet-4-6 (fast, supports PDF + Word + text).
# For maximum quality you can use claude-opus-4-8.
ANTHROPIC_MODEL=claude-sonnet-4-6
